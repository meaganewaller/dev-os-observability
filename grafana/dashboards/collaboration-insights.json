{
  "uid": "devos-collaboration",
  "title": "DevOS: Collaboration Insights",
  "description": "How human and AI work together - session patterns, skills applied, and interaction styles",
  "tags": ["devos", "collaboration"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Session Patterns",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Session Archetypes",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Distribution of session types: sprint (focused burst), flow (steady work), marathon (long session)",
      "targets": [
        {
          "expr": "sum by (payload_archetype) (count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"session_duration\" | payload_archetype!=\"\" [$__range]))",
          "legendFormat": "{{payload_archetype}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": ["value", "percent"]
        },
        "pieType": "donut"
      }
    },
    {
      "id": 3,
      "title": "Session Duration Categories",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "How long sessions last: quick (<5m), short (5-15m), medium (15-60m), long (1-4h), marathon (4h+)",
      "targets": [
        {
          "expr": "sum by (payload_duration_category) (count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"session_end\" | payload_duration_category!=\"\" [$__range]))",
          "legendFormat": "{{payload_duration_category}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": ["value", "percent"]
        },
        "pieType": "donut"
      }
    },
    {
      "id": 4,
      "title": "Task List Usage",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Task completion events",
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"task_completed\" [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "displayName": "Tasks Completed",
          "noValue": "0"
        }
      }
    },
    {
      "id": 5,
      "title": "Total Sessions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"session_start\" [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "displayName": "Sessions",
          "noValue": "0"
        }
      }
    },
    {
      "id": 6,
      "title": "Avg Writes/Session",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 5 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Average file writes per session (throughput indicator)",
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" [$__range])) / sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"session_start\" [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "displayName": "Writes/Session"
        }
      }
    },
    {
      "id": 7,
      "title": "Avg Tests/Session",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 5 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Average test runs per session",
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"test_run\" [$__range])) / sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"session_start\" [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "displayName": "Tests/Session"
        }
      }
    },
    {
      "id": 8,
      "title": "Work Categories",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "id": 9,
      "title": "Change Types",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Categories of work: architecture, bugfix, feature, refactor, test, docs",
      "targets": [
        {
          "expr": "sum by (payload_change_type) (count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" | payload_change_type!=\"\" [$__range]))",
          "legendFormat": "{{payload_change_type}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": ["value", "percent"]
        },
        "pieType": "pie"
      }
    },
    {
      "id": 10,
      "title": "Risk Profile",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Risk levels of changes made",
      "targets": [
        {
          "expr": "sum by (payload_risk) (count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" | payload_risk!=\"\" [$__range]))",
          "legendFormat": "{{payload_risk}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": ["value", "percent"]
        },
        "pieType": "pie"
      }
    },
    {
      "id": 11,
      "title": "Change Types Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "How work categories change over time",
      "targets": [
        {
          "expr": "sum by (payload_change_type) (count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" | payload_change_type!=\"\" [$__interval]))",
          "legendFormat": "{{payload_change_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "stacking": { "mode": "normal" },
            "fillOpacity": 80
          },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 12,
      "title": "Guidance & Learning",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },
    {
      "id": 13,
      "title": "Cues Fired",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 19 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Contextual guidance injections",
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"cue_fired\" [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "noValue": "0"
        }
      }
    },
    {
      "id": 14,
      "title": "Tool Failures",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 19 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Tool execution failures",
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_failure\" [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "noValue": "0"
        }
      }
    },
    {
      "id": 15,
      "title": "Test Runs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 19 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Test execution events",
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"test_run\" [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "noValue": "0"
        }
      }
    },
    {
      "id": 16,
      "title": "Decisions Captured",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 19 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Decision tradeoffs recorded",
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"decision_tradeoff\" [$__range])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "noValue": "0"
        }
      }
    },
    {
      "id": 17,
      "title": "Top Cues Fired",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Which cues provide the most guidance",
      "targets": [
        {
          "expr": "topk(10, sum by (payload_cue_id) (count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"cue_fired\" | payload_cue_id!=\"\" [$__range])))",
          "legendFormat": "{{payload_cue_id}}",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 18,
      "title": "Cue Triggers by Type",
      "type": "piechart",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 23 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "What triggers cue activation: prompt, bash, tool, etc.",
      "targets": [
        {
          "expr": "sum by (payload_trigger_type) (count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"cue_fired\" | payload_trigger_type!=\"\" [$__range]))",
          "legendFormat": "{{payload_trigger_type}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "right",
          "showLegend": true
        },
        "pieType": "pie"
      }
    },
    {
      "id": 19,
      "title": "Activity Over Time",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 23 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" [$__interval]))",
          "legendFormat": "Writes",
          "refId": "A"
        },
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"test_run\" [$__interval]))",
          "legendFormat": "Tests",
          "refId": "B"
        },
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_failure\" [$__interval]))",
          "legendFormat": "Failures",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "id": 20,
      "title": "Recent Collaboration Events",
      "type": "logs",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 27 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=~\"session_start|session_end|decision_tradeoff|large_change\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
