{
  "uid": "devos-mission-control",
  "title": "DevOS: Mission Control",
  "tags": ["devos", "overview"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "System Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Hook Success Rate",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Percentage of hooks that complete successfully",
      "targets": [
        {
          "expr": "(sum(count_over_time({service_name=\"devos\", log_source=\"hook-health\"} | json | status=\"success\" [$__range])) / sum(count_over_time({service_name=\"devos\", log_source=\"hook-health\"} [$__range])) * 100) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "id": 22,
      "title": "Tool Failure Rate",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Tool failures per 100 writes (lower is better)",
      "targets": [
        {
          "expr": "(sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_failure\" [$__range])) / (sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" [$__range])) + 0.001) * 100) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 200,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Friction Rate",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Friction events per 100 writes (lower is better)",
      "targets": [
        {
          "expr": "(sum(count_over_time({service_name=\"devos\", log_source=\"friction\"} [$__range])) / (sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" [$__range])) + 0.001) * 100) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 300,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Reversal Rate",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Work undone per 100 writes (lower is better)",
      "targets": [
        {
          "expr": "(sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"reversal\" [$__range])) / (sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" [$__range])) + 0.001) * 100) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 10,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 7 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Test Pass Rate",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Percentage of test runs that pass",
      "targets": [
        {
          "expr": "(sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"test_run\" | payload_result=\"pass\" [$__range])) / (sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"test_run\" [$__range])) + 0.001) * 100) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 23,
      "title": "Cue Effectiveness",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Cues fired per friction event (higher = more proactive)",
      "targets": [
        {
          "expr": "((sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"cue_fired\" [$__range])) + 0.001) / (sum(count_over_time({service_name=\"devos\", log_source=\"friction\"} [$__range])) + 0.001)) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "min": 0,
          "max": 2,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.6 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Activity",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false
    },
    {
      "id": 7,
      "title": "Sessions",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"session_start\" [$__range])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "fixedColor": "blue", "mode": "fixed" }
        }
      }
    },
    {
      "id": 8,
      "title": "Writes",
      "type": "stat",
      "gridPos": { "h": 3, "w": 3, "x": 4, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" [$__range])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "fixedColor": "green", "mode": "fixed" }
        }
      }
    },
    {
      "id": 9,
      "title": "Failures",
      "type": "stat",
      "gridPos": { "h": 3, "w": 3, "x": 7, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "All tool failures",
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_failure\" [$__range])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      }
    },
    {
      "id": 10,
      "title": "Tests",
      "type": "stat",
      "gridPos": { "h": 3, "w": 3, "x": 10, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"test_run\" [$__range])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "fixedColor": "purple", "mode": "fixed" }
        }
      }
    },
    {
      "id": 11,
      "title": "Cues Fired",
      "type": "stat",
      "gridPos": { "h": 3, "w": 3, "x": 13, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"cue_fired\" [$__range])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "fixedColor": "orange", "mode": "fixed" }
        }
      }
    },
    {
      "id": 12,
      "title": "Friction",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 16, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"friction\"} [$__range])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "id": 25,
      "title": "Hooks",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 20, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"hook-health\"} [$__range])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "fixedColor": "super-light-blue", "mode": "fixed" }
        }
      }
    },
    {
      "id": 13,
      "title": "Activity Over Time",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 16, "x": 0, "y": 11 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" [$__interval])) or vector(0)",
          "legendFormat": "Writes",
          "refId": "A"
        },
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_failure\" [$__interval])) or vector(0)",
          "legendFormat": "Failures",
          "refId": "B"
        },
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"friction\"} [$__interval])) or vector(0)",
          "legendFormat": "Friction",
          "refId": "C"
        },
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"test_run\" [$__interval])) or vector(0)",
          "legendFormat": "Tests",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "pointSize": 5
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Writes" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Failures" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Friction" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Tests" },
            "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 14,
      "title": "Failure Breakdown",
      "type": "piechart",
      "gridPos": { "h": 7, "w": 4, "x": 16, "y": 11 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Distribution of tool failures by tool type",
      "targets": [
        {
          "expr": "sum by (payload_tool) (count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_failure\" | payload_tool!=\"\" [$__range]))",
          "legendFormat": "{{payload_tool}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 24,
      "title": "Friction by Domain",
      "type": "piechart",
      "gridPos": { "h": 7, "w": 4, "x": 20, "y": 11 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (domain) (count_over_time({service_name=\"devos\", log_source=\"friction\"} | json | domain!=\"\" [$__range]))",
          "legendFormat": "{{domain}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 15,
      "title": "Quality Signals",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },
    {
      "id": 16,
      "title": "Reversals",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 19 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"reversal\" [$__range])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 17,
      "title": "Large Changes",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 19 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"large_change\" [$__range])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      }
    },
    {
      "id": 18,
      "title": "Context Compacts",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 8, "y": 19 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"context_compact\" [$__range])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      }
    },
    {
      "id": 19,
      "title": "Opinions Sought",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 19 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"prompt_opinion\" [$__range])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "fixedColor": "purple", "mode": "fixed" }
        }
      }
    },
    {
      "id": 20,
      "title": "Event Distribution",
      "type": "piechart",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 19 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (event_type) (count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type!=\"\" [$__range]))",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 21,
      "title": "Recent Friction Events",
      "type": "logs",
      "gridPos": { "h": 6, "w": 16, "x": 0, "y": 22 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=\"devos\", log_source=\"friction\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "wrapLogMessage": false,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
