      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 12,
      "title": "Decision Tradeoffs",
      "description": "Captured architectural decisions",
      "type": "logs",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 34},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"devos\"} | log_source=\"dev-os-events\" | json | event_type=\"tradeoff_auto_capture\"",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 13,
      "title": "Activity Over Time",
      "description": "All events timeline",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 41},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (event_type) (count_over_time({service_name=\"devos\"} | log_source=\"dev-os-events\" | json [$__interval]))",
          "queryType": "range",
          "legendFormat": "{{event_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "stacking": {"mode": "normal"}
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        }
      }
    },
    {
      "id": 14,
      "title": "Friction Over Time",
      "description": "Friction events by subdomain",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 49},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (subdomain) (count_over_time({service_name=\"devos\"} | log_source=\"friction\" | json [$__interval]))",
          "queryType": "range",
          "legendFormat": "{{subdomain}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "stacking": {"mode": "normal"}
          },
          "color": {"mode": "palette-classic"}
        }
      }
    }
  ]
}
