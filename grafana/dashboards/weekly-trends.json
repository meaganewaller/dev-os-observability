{
  "uid": "devos-weekly",
  "title": "DevOS: Weekly Trends",
  "tags": ["devos", "trends"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1h",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Friction Events - Weekly",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"friction\"} [1w])) or vector(0)",
          "legendFormat": "Friction Events",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Productivity - Weekly",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" [1w])) or vector(0)",
          "legendFormat": "Writes",
          "refId": "A"
        },
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"task_completed\" [1w])) or vector(0)",
          "legendFormat": "Tasks Completed",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80
          }
        }
      }
    },
    {
      "id": 3,
      "title": "This Week Friction",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Friction events this week",
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"friction\"} [7d])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "displayName": "This Week",
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Last Week Friction",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"friction\"} [7d] offset 7d)) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "displayName": "Last Week",
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Sessions This Week",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"session_start\" [7d])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "displayName": "Sessions",
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Tests This Week",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"test_run\" [7d])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "displayName": "Test Runs",
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [{ "color": "purple", "value": null }]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Friction by Subdomain - 4 Week Trend",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (subdomain) (count_over_time({service_name=\"devos\", log_source=\"friction\"} | json | subdomain!=\"\" [1w]))",
          "legendFormat": "{{subdomain}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "spanNulls": true
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Hook Success Rate Trend",
      "description": "Percentage of successful hook executions",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "(sum(count_over_time({service_name=\"devos\", log_source=\"hook-health\"} | json | status=\"success\" [1d])) / sum(count_over_time({service_name=\"devos\", log_source=\"hook-health\"} [1d])) * 100) or vector(0)",
          "legendFormat": "Success Rate %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Daily Activity",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} [1d])) or vector(0)",
          "legendFormat": "Events",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Week-over-Week Comparison",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "Friction Change",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 29 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Change in friction events vs last week (negative is better)",
      "targets": [
        {
          "expr": "(sum(count_over_time({service_name=\"devos\", log_source=\"friction\"} [7d])) or vector(0)) - (sum(count_over_time({service_name=\"devos\", log_source=\"friction\"} [7d] offset 7d)) or vector(0))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "id": 12,
      "title": "Sessions Change",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 29 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Change in sessions vs last week",
      "targets": [
        {
          "expr": "(sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"session_start\" [7d])) or vector(0)) - (sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"session_start\" [7d] offset 7d)) or vector(0))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0 },
              { "color": "green", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "id": 13,
      "title": "Hook Failures Change",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 29 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Change in hook failures vs last week (negative is better)",
      "targets": [
        {
          "expr": "(sum(count_over_time({service_name=\"devos\", log_source=\"hook-health\"} | json | status=\"failure\" [7d])) or vector(0)) - (sum(count_over_time({service_name=\"devos\", log_source=\"hook-health\"} | json | status=\"failure\" [7d] offset 7d)) or vector(0))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      }
    }
  ]
}
