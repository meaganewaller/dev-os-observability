{
  "uid": "devos-project-focus",
  "title": "DevOS: Project Focus",
  "description": "What we work on - change types, risk levels, and work patterns",
  "tags": ["devos", "projects", "focus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Work Distribution",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Change Categories",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Types of changes: architecture, bugfix, feature, refactor, test, docs",
      "targets": [
        {
          "expr": "sum by (payload_change_type) (count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" | payload_change_type!=\"\" [$__range]))",
          "legendFormat": "{{payload_change_type}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": ["value", "percent"]
        },
        "pieType": "donut"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 3,
      "title": "Risk Profile",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Risk levels of file modifications",
      "targets": [
        {
          "expr": "sum by (payload_risk) (count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" | payload_risk!=\"\" [$__range]))",
          "legendFormat": "{{payload_risk}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": ["value", "percent"]
        },
        "pieType": "donut"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "low" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "medium" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "high" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 4,
      "title": "Test Results",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Test run outcomes",
      "targets": [
        {
          "expr": "sum by (payload_result) (count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"test_run\" | payload_result!=\"\" [$__range]))",
          "legendFormat": "{{payload_result}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": ["value", "percent"]
        },
        "pieType": "donut"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "passed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "failed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 5,
      "title": "Activity Breakdown",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "id": 6,
      "title": "Total Writes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" [$__range])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "displayName": "File Writes",
          "noValue": "0"
        }
      }
    },
    {
      "id": 7,
      "title": "Architecture",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" | payload_change_type=\"architecture\" [$__range])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "displayName": "Architecture",
          "noValue": "0"
        }
      }
    },
    {
      "id": 8,
      "title": "Bug Fixes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" | payload_change_type=\"bugfix\" [$__range])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "displayName": "Bug Fixes",
          "noValue": "0"
        }
      }
    },
    {
      "id": 9,
      "title": "Tests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" | payload_change_type=\"test\" [$__range])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "displayName": "Tests",
          "noValue": "0"
        }
      }
    },
    {
      "id": 10,
      "title": "Refactors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" | payload_change_type=\"refactor\" [$__range])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "displayName": "Refactors",
          "noValue": "0"
        }
      }
    },
    {
      "id": 11,
      "title": "Test Runs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"test_run\" [$__range])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "cyan", "mode": "fixed" },
          "displayName": "Test Runs",
          "noValue": "0"
        }
      }
    },
    {
      "id": 12,
      "title": "Trends",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 13,
      "title": "Change Types Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (payload_change_type) (count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" | payload_change_type!=\"\" [$__interval]))",
          "legendFormat": "{{payload_change_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "stacking": { "mode": "normal" },
            "fillOpacity": 80
          },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 14,
      "title": "Risk Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (payload_risk) (count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" | payload_risk!=\"\" [$__interval]))",
          "legendFormat": "{{payload_risk}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "stacking": { "mode": "normal" },
            "fillOpacity": 80
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "low" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "medium" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "high" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 15,
      "title": "Quality Indicators",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "id": 16,
      "title": "Architecture Ratio",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Architecture work as % of total (higher = more strategic work)",
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" | payload_change_type=\"architecture\" [$__range])) / (sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" [$__range])) > 0 or vector(1)) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 50,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "green", "value": 10 },
              { "color": "blue", "value": 25 }
            ]
          }
        }
      }
    },
    {
      "id": 17,
      "title": "Bugfix Ratio",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Bug fixes as % of total (lower = better quality)",
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" | payload_change_type=\"bugfix\" [$__range])) / (sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" [$__range])) > 0 or vector(1)) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 50,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 40 }
            ]
          }
        }
      }
    },
    {
      "id": 18,
      "title": "Test Ratio",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Test changes as % of total (higher = better coverage)",
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" | payload_change_type=\"test\" [$__range])) / (sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" [$__range])) > 0 or vector(1)) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 50,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "green", "value": 25 }
            ]
          }
        }
      }
    },
    {
      "id": 19,
      "title": "Low Risk Ratio",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Low risk changes as % of total (higher = safer)",
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" | payload_risk=\"low\" [$__range])) / (sum(count_over_time({service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\" [$__range])) > 0 or vector(1)) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 70 }
            ]
          }
        }
      }
    },
    {
      "id": 20,
      "title": "Recent File Changes",
      "type": "logs",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 29 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=\"devos\", log_source=\"dev-os-events\"} | json | event_type=\"tool_write\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
