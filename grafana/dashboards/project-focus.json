{
  "uid": "devos-project-focus",
  "title": "DevOS: Project Focus",
  "description": "What we work on - projects, file types, and change categories",
  "tags": ["devos", "projects", "focus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Work Distribution",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Change Categories",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Types of changes: architecture, bugfix, feature, refactor, test, docs",
      "targets": [
        {
          "expr": "sum by (change_type) (count_over_time({service_name=\"devos\"} | log_source=\"dev-os-events\" | json | event_type=\"tool_write\" | change_type!=\"\" [$__range]))",
          "legendFormat": "{{change_type}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": ["value", "percent"]
        },
        "pieType": "donut"
      }
    },
    {
      "id": 3,
      "title": "Risk Profile",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Risk levels of file modifications",
      "targets": [
        {
          "expr": "sum by (risk) (count_over_time({service_name=\"devos\"} | log_source=\"dev-os-events\" | json | event_type=\"tool_write\" | risk!=\"\" [$__range]))",
          "legendFormat": "{{risk}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": ["value", "percent"]
        },
        "pieType": "donut"
      }
    },
    {
      "id": 4,
      "title": "Skills Applied",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Engineering skills used in changes",
      "targets": [
        {
          "expr": "sum by (skills) (count_over_time({service_name=\"devos\"} | log_source=\"dev-os-events\" | json | event_type=\"tool_write\" | skills!=\"\" [$__range]))",
          "legendFormat": "{{skills}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": ["value", "percent"]
        },
        "pieType": "donut"
      }
    },
    {
      "id": 5,
      "title": "Activity Breakdown",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "id": 6,
      "title": "Total Writes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\"} | log_source=\"dev-os-events\" | json | event_type=\"tool_write\" [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "displayName": "File Writes"
        }
      }
    },
    {
      "id": 7,
      "title": "Architecture Changes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\"} | log_source=\"dev-os-events\" | json | event_type=\"tool_write\" | change_type=\"architecture\" [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "displayName": "Architecture"
        }
      }
    },
    {
      "id": 8,
      "title": "Bug Fixes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\"} | log_source=\"dev-os-events\" | json | event_type=\"tool_write\" | change_type=\"bugfix\" [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "displayName": "Bug Fixes"
        }
      }
    },
    {
      "id": 9,
      "title": "Test Changes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\"} | log_source=\"dev-os-events\" | json | event_type=\"tool_write\" | change_type=\"test\" [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "displayName": "Tests"
        }
      }
    },
    {
      "id": 10,
      "title": "High Risk Changes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\"} | log_source=\"dev-os-events\" | json | event_type=\"tool_write\" | risk=\"high\" [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "displayName": "High Risk",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 25 }
            ]
          }
        }
      }
    },
    {
      "id": 11,
      "title": "Domain Modeling",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\"} | log_source=\"dev-os-events\" | json | event_type=\"domain_modeling\" [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "displayName": "Domain Modeling"
        }
      }
    },
    {
      "id": 12,
      "title": "Trends",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 13,
      "title": "Change Types Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (change_type) (count_over_time({service_name=\"devos\"} | log_source=\"dev-os-events\" | json | event_type=\"tool_write\" | change_type!=\"\" [$__interval]))",
          "legendFormat": "{{change_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "stacking": { "mode": "normal" },
            "fillOpacity": 80
          },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 14,
      "title": "Risk Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (risk) (count_over_time({service_name=\"devos\"} | log_source=\"dev-os-events\" | json | event_type=\"tool_write\" | risk!=\"\" [$__interval]))",
          "legendFormat": "{{risk}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "stacking": { "mode": "normal" },
            "fillOpacity": 80
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "low" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "medium" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "high" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 15,
      "title": "Quality Indicators",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "id": 16,
      "title": "Architecture Ratio",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Architecture work as % of total (higher = more strategic work)",
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\"} | log_source=\"dev-os-events\" | json | event_type=\"tool_write\" | change_type=\"architecture\" [$__range])) / sum(count_over_time({service_name=\"devos\"} | log_source=\"dev-os-events\" | json | event_type=\"tool_write\" [$__range])) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "green", "value": 20 },
              { "color": "blue", "value": 40 }
            ]
          }
        }
      }
    },
    {
      "id": 17,
      "title": "Bugfix Ratio",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Bug fixes as % of total (lower = better quality, or less maintenance)",
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\"} | log_source=\"dev-os-events\" | json | event_type=\"tool_write\" | change_type=\"bugfix\" [$__range])) / sum(count_over_time({service_name=\"devos\"} | log_source=\"dev-os-events\" | json | event_type=\"tool_write\" [$__range])) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 18,
      "title": "Test Ratio",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Test changes as % of total (higher = better coverage)",
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\"} | log_source=\"dev-os-events\" | json | event_type=\"tool_write\" | change_type=\"test\" [$__range])) / sum(count_over_time({service_name=\"devos\"} | log_source=\"dev-os-events\" | json | event_type=\"tool_write\" [$__range])) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "green", "value": 30 }
            ]
          }
        }
      }
    },
    {
      "id": 19,
      "title": "High Risk Ratio",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "High risk changes as % of total (lower = safer)",
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devos\"} | log_source=\"dev-os-events\" | json | event_type=\"tool_write\" | risk=\"high\" [$__range])) / sum(count_over_time({service_name=\"devos\"} | log_source=\"dev-os-events\" | json | event_type=\"tool_write\" [$__range])) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 50,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      }
    },
    {
      "id": 20,
      "title": "Recent File Changes",
      "type": "logs",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 29 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=\"devos\"} | log_source=\"dev-os-events\" | json | event_type=\"tool_write\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
